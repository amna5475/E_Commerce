{
	"info": {
		"_postman_id": "e-commerce-api-collection",
		"name": "E-commerce Marketplace API",
		"description": "Full collection for testing all endpoints in the Daraz Clone project.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"Test Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"03001234567\",\n  \"role\": \"admin\"\n}",
							"options": { "json": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register" }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}",
							"options": { "json": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				}
			]
		},
		{
			"name": "2. Seller Management",
			"item": [
				{
					"name": "Apply for Seller",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"shop_name\": \"Tech World\",\n  \"description\": \"Electronics shop\",\n  \"ntn_number\": \"1234567-8\",\n  \"bank_name\": \"HBL\",\n  \"bank_account\": \"123456\",\n  \"bank_iban\": \"PK00123\"\n}",
							"options": { "json": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/sellers/register" }
					}
				},
				{
					"name": "Approve Seller (Admin)",
					"request": {
						"method": "PUT",
						"header": [],
						"url": { "raw": "{{base_url}}/sellers/:id/approve" }
					}
				}
			]
		},
		{
			"name": "3. Products",
			"item": [
				{
					"name": "Get All Products",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/products" }
					}
				},
				{
					"name": "Create Product (Seller)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Laptop\",\n  \"base_price\": 150000,\n  \"category_id\": \"\",\n  \"brand_id\": \"\",\n  \"variants\": [\n    { \"color\": \"Black\", \"size\": \"16GB\", \"price\": 150000, \"stock_qty\": 5, \"sku\": \"LAP-001\" }\n  ]\n}",
							"options": { "json": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/products" }
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": { "type": "text/javascript", "exec": [""] }
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000/api" },
		{ "key": "token", "value": "" }
	]
}
